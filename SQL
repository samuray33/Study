Начал изучать SQL (PostgreSql)

- создание таблицы
1) вариант (базовый с минимальным модофикатором)
CREATE TABLE persons(
	id SERIAL PRIMARY KEY,
  	name TEXT,
  	surname TEXT,
  	age INTEGER
);

2) вариань (правильный с полным модификатором)
CREATE TABLE persons(
	id SERIAL PRIMARY KEY,
  	name TINYTEXT not NULL,
  	surname TINYTEXT not NULL,
  	age INTEGER DEFAULT 18
);

- добавление данных в таблицу
insert into persons (name, surname, age) VALUES ('Gabriel', 'Apalonov', 22)

- чтение таблицы 
SELECT * FROM person

- изменеие таблицы 


- удаление таблицы
DROP TABLE persons
